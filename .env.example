# Cursor Agent（参考 weixin-agent-bridge）
AGENT_CMD=agent
AGENT_INVOKE_MODE=args
AGENT_TIMEOUT_MS=120000
AGENT_ARGS_JSON=["-f","--print","--output-format","stream-json","--approve-mcps=true","--model=Auto"]
AGENT_CWD=
# Agent 子进程连续无输出则终止（默认 600000=10 分钟；0/off 表示不限制空闲超时）
AGENT_IDLE_TIMEOUT_MS=600000
AGENT_MAX_RUNTIME_MS=900000
# Agent 输出模式（省略时按 AGENT_INVOKE_MODE 推导）
# AGENT_OUTPUT_MODE=
# 强制追加 --output-format stream-json
# AGENT_FORCE_STREAM_JSON=0
# 禁用自动追加 --print（仅当你自行在 AGENT_ARGS_JSON 里控制输出时使用）
# AGENT_NO_AUTO_PRINT_FLAG=0


# 微信 bot 存储
WECHATBOT_STORAGE_DIR=./data/.wechatbot
WECHATBOT_LOG_LEVEL=info
# 可选：覆盖 iLink API 根地址（默认 https://ilinkai.weixin.qq.com）
# WECHATBOT_BASE_URL=https://ilinkai.weixin.qq.com
# 扫码登录阶段网络抖动 / ECONNRESET 时自动重试
WECHATBOT_LOGIN_MAX_RETRIES=12
WECHATBOT_LOGIN_RETRY_MS=4000

# ── 出站代理（微信 SDK 用 Node 内置 fetch 访问 iLink，默认直连）────────────
# 若抓包仍显示「直连 TLS」：仅设 NODE_USE_ENV_PROXY=1 在部分环境下不会作用到全局 fetch。
# 本仓库在启动时会调用 undici 的 setGlobalDispatcher(EnvHttpProxyAgent)，只要配置了下面任一变量即走代理：
#   HTTPS_PROXY / HTTP_PROXY（或 https_proxy / http_proxy）
# 端口须为 HTTP 代理（Clash「混合/Mixed」或明确 HTTP 端口）；纯 SOCKS5 地址不能填成 http://…，需换 HTTP 端口或开 mixed。
# 关闭本行为：WECHATBOT_FETCH_USE_PROXY=0
# NODE_USE_ENV_PROXY=1
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# 会话 chatId（create-chat / --resume）
SESSION_STORE_PATH=./data/sessions.json
CHAT_SESSION_ENABLE=1

# 可选：限权用户（空=不限制）
ALLOWED_USER_IDS=
# 多用户用户库（当文件中有用户记录时，仅启用用户可访问）
# USER_STORE_PATH=./data/users.json
# 管理员登录口令（优先级高于持久化口令文件）
# ADMIN_LOGIN_PASSWORD=
# 管理员口令持久化文件（可由 /用户 password 更新）
# ADMIN_AUTH_PATH=./data/admin-auth.json

# 语气 emoji：full | minimal | off
WX_EMOJI_STYLE=full
WX_AGENT_STREAM_JSON=1
WX_AGENT_PROGRESS_MIN_INTERVAL_MS=2500
WX_AGENT_STREAM_SEGMENT_AFTER_CHARS=50
# WX_AGENT_PROGRESS_MAX_CHARS=1200

# 周期任务（Node 读写状态；作业入口默认 run.mjs）
PERIODIC_STATE_PATH=./data/periodic-state.json
PERIODIC_JOB_ROOT=./data/periodic-jobs
PERIODIC_SCAN_MS=15000
PERIODIC_NOTIFY_SUCCESS=0
# 定时脚本失败默认不主动推送（仅写入任务 lastError，发 /周期 详情 查看）
# 手动执行 /周期 run <ID> 时会在会话内返回失败摘要
# 脚本任务执行超时（毫秒）；默认取 COMPILE_TIMEOUT_MS，否则 600000
PERIODIC_SCRIPT_TIMEOUT_MS=
# 推送正文最大字符（stdout 裁剪）
PERIODIC_SCRIPT_MAX_STDOUT_CHARS=4000
# 脚本 stdout 整段作为一条微信推送（多行用 \\n 分隔，不再按行拆条）
# 失败消息落盘队列路径（发送成功后自动删除）
# PERIODIC_RETRY_QUEUE_PATH=./data/periodic-retry-queue.json
# 周期作业 Node 解释器（可选；默认与主进程相同 node）
# NODE_CMD=
# PERIODIC_NODE_CMD=

# 构建/脚本相关超时与产物大小（仍被 /代码 发产物、周期脚本等使用）
COMPILE_TIMEOUT_MS=600000
COMPILE_MAX_SEND_MB=20

# /代码 模块：已登记项目、默认产物 glob、本地根目录白名单
# CODE_PROJECTS_PATH=./data/code-projects.json
# 逗号分隔的绝对路径前缀，非空时仅允许这些目录下的「添加 <本地路径>」
# CODE_PROJECT_ROOT_ALLOWLIST=
# 未设置项目级「产物 glob」时，构建成功后用于匹配产物的相对路径（如 dist/*.exe）
# CODE_ARTIFACT_GLOB=
# 本机/SSH 执行 build.sh 超时（未设时回退 COMPILE_TIMEOUT_MS）
# CODE_BUILD_TIMEOUT_MS=
# 多轮向导（/向导、/菜单 进入；状态文件与超时）
# WIZARD_STATE_PATH=./data/wizard-state.json
# WIZARD_TTL_MS=1800000

# 收发调试（1=日志里打印 ← 接收 / → 发送摘要，敏感片段脱敏）
WECHAT_TRACE_IO=0
# 1=在运行终端同步打印 [wx-in] / [wx-out]（可与 WECHAT_TRACE_IO 同时开启）
WECHAT_TERMINAL_IO=0

# 用户级「/环境 set」写入的键值 JSON（按 userId 隔离；可用 INJECTED_ENV_PATH 覆盖路径）
# INJECTED_ENV_PATH=./data/injected-env.json

# Steam 好友状态监控（密钥 + SteamID + 收件人 必填）
STEAM_WEB_API_KEY=
STEAM_MONITOR_STEAM_ID=
STEAM_MONITOR_NOTIFY_USER_ID=
STEAM_MONITOR_PROXY_URL=http://127.0.0.1:10808
STEAM_MONITOR_INTERVAL_MS=120000
# STEAM_MONITOR_NO_PROXY=1
# STEAM_MONITOR_STATE_PATH=./data/steam-friends-state.json
# 同一轮里多条变更时分条发送的间隔（毫秒；兼容旧名 STEAM_MONITOR_NOTIFY_GAP_MS）
STEAM_MONITOR_MESSAGE_GAP_MS=450

# 子实例冷启动恢复：login 若长时间不返回则超时失败
# BOT_RESTORE_LOGIN_TIMEOUT_MS=15000
# 后台启动长轮询后，等待 bot.isRunning 的最长时间（默认 60000；SDK 的 start() 本身会永久 await 轮询）
# BOT_POLL_READY_TIMEOUT_MS=60000

LOG_LEVEL=info
