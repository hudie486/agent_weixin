# Cursor Agent（参考 weixin-agent-bridge）
AGENT_CMD=agent
AGENT_INVOKE_MODE=args
AGENT_TIMEOUT_MS=120000
AGENT_ARGS_JSON=["-f","--print","--output-format","stream-json","--approve-mcps=true","--model=Auto"]
AGENT_CWD=
# Agent 子进程连续无输出则终止（默认 600000=10 分钟；0/off 表示不限制空闲超时）
AGENT_IDLE_TIMEOUT_MS=600000
AGENT_MAX_RUNTIME_MS=900000
# Agent 输出模式（省略时按 AGENT_INVOKE_MODE 推导）
# AGENT_OUTPUT_MODE=
# 强制追加 --output-format stream-json
# AGENT_FORCE_STREAM_JSON=0
# 禁用自动追加 --print（仅当你自行在 AGENT_ARGS_JSON 里控制输出时使用）
# AGENT_NO_AUTO_PRINT_FLAG=0
# Agent 运行后端：cli=spawn cursor-agent 子进程（默认，沿用上面的 AGENT_CMD/AGENT_ARGS_JSON）
#                 sdk=@cursor/sdk 本进程内 local 模式（去掉 CLI 子进程，需 Node>=22.13）
# AGENT_BACKEND=cli
# sdk 后端必填：Cursor API Key 与本地模型（本地 agent 必须显式指定模型）
# CURSOR_API_KEY=
# AGENT_MODEL=composer-2.5


# 运行时数据根目录（默认 ./data；各 *\_PATH 可单独覆盖）
# DATA_DIR=./data

# 微信平台开关：0=不启动微信（不扫码、不登录），仅运行 QQ 等其它平台。默认开启。
# WECHAT_ENABLED=1
# 微信 bot 存储
WECHATBOT_STORAGE_DIR=./data/.wechatbot
WECHATBOT_LOG_LEVEL=info
# 可选：覆盖 iLink API 根地址（默认 https://ilinkai.weixin.qq.com）
# WECHATBOT_BASE_URL=https://ilinkai.weixin.qq.com
# 扫码登录阶段网络抖动 / ECONNRESET 时自动重试
WECHATBOT_LOGIN_MAX_RETRIES=12
WECHATBOT_LOGIN_RETRY_MS=4000

# ── 出站代理（微信 SDK 用 Node 内置 fetch 访问 iLink，默认直连）────────────
# 若抓包仍显示「直连 TLS」：仅设 NODE_USE_ENV_PROXY=1 在部分环境下不会作用到全局 fetch。
# 本仓库在启动时会调用 undici 的 setGlobalDispatcher(EnvHttpProxyAgent)，只要配置了下面任一变量即走代理：
#   HTTPS_PROXY / HTTP_PROXY（或 https_proxy / http_proxy）
# 也可仅设 STEAM_MONITOR_PROXY_URL（与 Steam 监控共用，启动时自动镜像到 HTTPS_PROXY/HTTP_PROXY）
# 端口须为 HTTP 代理（Clash「混合/Mixed」或明确 HTTP 端口）；纯 SOCKS5 地址不能填成 http://…，需换 HTTP 端口或开 mixed。
# 关闭本行为：WECHATBOT_FETCH_USE_PROXY=0
# NODE_USE_ENV_PROXY=1
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# 会话 chatId（create-chat / --resume）
SESSION_STORE_PATH=./data/sessions.json
CHAT_SESSION_ENABLE=1

# NLU 意图判定（DeepSeek OpenAI 兼容 API）
NLU_ENABLE=1
# NLU：全量命令由 DeepSeek 抽槽；未命中时默认继续走 Agent（设 0 则仅提示斜杠命令）
# NLU_AGENT_FALLBACK_ON_MISS=1
# NLU_STYLE_ENABLE=1 仅润色 NLU 填参/消歧等交互话术；命令结果（列表、成功失败）不润色
DEEPSEEK_API_KEY=
# NLU_LLM_BASE_URL=https://api.deepseek.com
# NLU 模型请显式指定（不要依赖默认）。注意：deepseek-chat 将于 2026/07/24 下线，
# 届时改用后继模型（如 deepseek-v4-flash，非思考模式）。启动日志会在用到 deepseek-chat 时告警。
NLU_LLM_MODEL=deepseek-chat
# NLU_LLM_TIMEOUT_MS=30000
# NLU_CONFIDENCE_MIN=0.6
# NLU_INTERRUPT_MIN=0.85
# INTERACTION_STATE_PATH=./data/interaction-state.json

# 可选：限权用户（空=不限制）
ALLOWED_USER_IDS=
# 多用户用户库（当文件中有用户记录时，仅启用用户可访问）
# USER_STORE_PATH=./data/users.json
# 管理员登录口令（优先级高于持久化口令文件）
# ADMIN_LOGIN_PASSWORD=
# 管理员口令持久化文件（可由 /用户 password 更新）
# ADMIN_AUTH_PATH=./data/admin-auth.json

# 命令「确认类」回复是否调 LLM 换花样改写（默认 0=用预设池随机，零 token）；
# =1 时 /测试 等确认会调 DeepSeek 生成更自然的说法，约 0.05 分/次。事实由命令确定，LLM 只改措辞。
# CMD_STYLE_ENABLE=0
# 别名表存储（/别名 添加 教机器人把整句当某命令；用户级隔离 + 全局回退）
# ALIAS_STORE_PATH=./data/aliases.json
# 别名 auto-suggest：短自然语言未命中、随后手动执行某命令时，提示「回复『好』把它设成别名」。默认开启。
# ALIAS_SUGGEST_ENABLE=1

# ── 向量 / 用户记忆 / 语义意图（全本地开源，默认全关；详见 docs/vector-plan.md）──
# 向量总开关：开启后用本地 bge 嵌入模型（首次自动下载到 EMBED_CACHE_DIR）
# VECTOR_ENABLE=0
# EMBED_MODEL=Xenova/bge-small-zh-v1.5
# EMBED_CACHE_DIR=data/models
# EMBED_OFFLINE=0          # =1 纯本地、不联网下载（需先预置模型）
# 访问不到 huggingface.co 时用镜像下载模型（国内常用）；也可走 HTTPS_PROXY
# HF_ENDPOINT=https://hf-mirror.com
# 用户记忆：/记忆 命令记住称呼/偏好；开启后对话会注入用户档案（向量召回还需 VECTOR_ENABLE=1）
# MEMORY_ENABLE=0
# MEMORY_RECALL_TOPK=4
# MEMORY_RECALL_MIN=0.6
# MEMORY_DEDUPE_MIN=0.9
# 自动从对话抽取事实入库（费 token，默认关；会给每条事实打 importance）
# MEMORY_AUTO_EXTRACT=0
# MEMORY_EXTRACT_MIN_LEN=6
# 记忆曲线（类人遗忘+强化+重要度）：
# MEMORY_HALFLIFE_DAYS=7          # 基础半衰期；importance 与强化次数会延长它
# MEMORY_FORGOTTEN_RETENTION=0.05 # 召回时低于此保留度的笔记不再浮现
# MEMORY_ALWAYS_IMPORTANCE=0.8    # importance≥此值的笔记每轮必注入（如过敏/身份）
# MEMORY_ALWAYS_MAX=3
# MEMORY_REINFORCE_MIN=0.7        # 召回命中≥此相似度则强化（间隔重复）
# MEMORY_REINFORCE_COOLDOWN_MS=21600000
# 巩固（P5，确定性、零 token，主进程内定时跑；默认关）：
# MEMORY_CONSOLIDATE_ENABLE=0
# MEMORY_CONSOLIDATE_INTERVAL_MS=21600000
# MEMORY_PRUNE_RETENTION=0.15     # 低于此且不重要的笔记被遗忘清除
# MEMORY_KEEP_IMPORTANCE=0.8      # importance≥此值的永不被清除
# 语义意图：精确别名未命中时用向量找近义别名（需 VECTOR_ENABLE=1）
# INTENT_SEMANTIC_ENABLE=0
# INTENT_SEMANTIC_MIN=0.84     # ≥ 直接执行（保守，宁可反问也不误跑）
# INTENT_SEMANTIC_ASK=0.70     # [ASK,MIN) 反问确认（bge 近义短句约 0.7，可按 LOG_LEVEL=debug 打印的实际分数调）

# ── 联网检索（自建 SearXNG，给实时问题做 grounding；默认关）──
# 实时类问题（天气/新闻/股价…）或以「搜：」开头时，先查 SearXNG 再让模型据此回答并附来源。
# 一键安装本地 SearXNG：npm run searxng:setup（venv+pip，装到 searxng/）；之后随工程自启动
# WEBSEARCH_ENABLE=0
# SEARXNG_AUTOSTART=0                  # =1 时主进程启动时拉起本地 SearXNG（需先 searxng:setup）
# SEARXNG_URL=http://127.0.0.1:8888   # 自建实例地址；务必加进 NO_PROXY 以免被全局代理拦
# SEARXNG_HOME=                        # 默认 ./searxng
# WEBSEARCH_TOPK=4
# WEBSEARCH_TIMEOUT_MS=6000
# NO_PROXY=localhost,127.0.0.1
# 语气 emoji：full | minimal | off
# 状态 emoji：系统只在 成功/失败/警告 消息首行加一枚 ✅/❌/⚠️（文本已带表情则不加，防止 ✅✅）；
# LLM 生成的文本（Agent 进度/回复）原样放行，表情由 LLM 按需自加；off=完全不自动加
WX_EMOJI_STYLE=full
WX_AGENT_STREAM_JSON=1
WX_AGENT_PROGRESS_MIN_INTERVAL_MS=2500
WX_AGENT_STREAM_SEGMENT_AFTER_CHARS=50
# WX_AGENT_PROGRESS_MAX_CHARS=1200

# 周期任务（Node 读写状态；作业入口默认 run.mjs）
PERIODIC_STATE_PATH=./data/periodic-state.json
PERIODIC_JOB_ROOT=./data/periodic-jobs
PERIODIC_SCAN_MS=15000
PERIODIC_NOTIFY_SUCCESS=0
# 定时脚本失败默认不主动推送（仅写入任务 lastError，发 /周期 详情 查看）
# 手动执行 /周期 run <ID> 时会在会话内返回失败摘要
# 脚本任务执行超时（毫秒）；默认取 COMPILE_TIMEOUT_MS，否则 600000
PERIODIC_SCRIPT_TIMEOUT_MS=
# 推送正文最大字符（stdout 裁剪）
PERIODIC_SCRIPT_MAX_STDOUT_CHARS=4000
# 脚本 stdout 整段作为一条微信推送（多行用 \\n 分隔，不再按行拆条）
# 失败消息落盘队列：周期任务与微信/QQ 出站共用同一队列，统一用下方 OUTBOUND_RETRY_QUEUE_PATH。
# PERIODIC_RETRY_QUEUE_PATH 为旧名（仅在 OUTBOUND_RETRY_QUEUE_PATH 未设时回退；旧 periodic-retry-queue.json 会自动迁移）。
# 周期作业 Node 解释器（可选；默认与主进程相同 node）
# NODE_CMD=
# PERIODIC_NODE_CMD=

# Agent 长任务（生成/修改/修复）静默心跳：无文本输出超过该间隔就发一条“仍在工作”（0=关）
# PERIODIC_AGENT_HEARTBEAT_MS=120000

# QQ 发文件走限时下载链接（QQ 官方 C2C 不支持直发文件）：
# 手机要能打开链接需 WEB_BIND=0.0.0.0 且与本机同局域网；WEB_PUBLIC_ORIGIN 缺省自动用局域网 IP
# WEB_PUBLIC_ORIGIN=http://192.168.1.5:8787
# WEB_FILE_LINK_TTL_MS=86400000

# 生成脚本后的验证闭环：node --check + PERIODIC_PREVIEW=1 试跑，失败回喂 Agent 修复
# PERIODIC_SCAFFOLD_PREVIEW=1        # 0=生成后跳过试跑（只做语法检查）
# PERIODIC_SCAFFOLD_FIX_ROUNDS=2     # 试跑失败后 Agent 修复轮数
# PERIODIC_PREVIEW_TIMEOUT_MS=180000

# 失败自动介入：同一错误签名连续失败 N 次 → 向审批人/归属者提议「修复/不修」
# PERIODIC_AUTO_REPAIR_ENABLE=1      # 0=关闭
# PERIODIC_REPAIR_AFTER_FAILS=2
# PERIODIC_REPAIR_MAX_ATTEMPTS=1     # 同签名最多修几次（防修复循环）
# PERIODIC_REPAIR_COOLDOWN_MS=21600000
# PERIODIC_REPAIR_PENDING_TIMEOUT_MS=86400000

# 运维巡检简报：定期汇总近 N 天运行历史，LLM 写简报推送给任务归属者
# PERIODIC_OPS_REPORT_ENABLE=1       # 0=关闭；无 DEEPSEEK_API_KEY 时发纯统计摘要
# PERIODIC_OPS_REPORT_INTERVAL_H=24
# PERIODIC_OPS_REPORT_WINDOW_D=7

# 构建/脚本相关超时与产物大小（仍被 /代码 发产物、周期脚本等使用）
COMPILE_TIMEOUT_MS=600000
COMPILE_MAX_SEND_MB=20

# /代码 模块：已登记项目、默认产物 glob、本地根目录白名单
# CODE_PROJECTS_PATH=./data/code-projects.json
# 逗号分隔的绝对路径前缀，非空时仅允许这些目录下的「添加 <本地路径>」
# CODE_PROJECT_ROOT_ALLOWLIST=
# 未设置项目级「产物 glob」时，构建成功后用于匹配产物的相对路径（如 dist/*.exe）
# CODE_ARTIFACT_GLOB=
# 本机/SSH 执行 build.sh 超时（未设时回退 COMPILE_TIMEOUT_MS）
# CODE_BUILD_TIMEOUT_MS=
# 多轮向导（/向导、/菜单 进入；状态文件与超时）
# WIZARD_STATE_PATH=./data/wizard-state.json
# WIZARD_TTL_MS=1800000

# 收发调试（微信 + QQ 统一 [session-io] 日志；敏感片段脱敏）
SESSION_IO=1
# 兼容旧变量：WECHAT_TRACE_IO=1 或 LOG_LEVEL=debug 亦可开启
WECHAT_TRACE_IO=0
WECHAT_TERMINAL_IO=0

# 用户级「/环境 set」写入的键值 JSON（按 userId 隔离；可用 INJECTED_ENV_PATH 覆盖路径）
# INJECTED_ENV_PATH=./data/injected-env.json

# Steam 好友状态监控（密钥 + SteamID + 收件人 必填）
STEAM_WEB_API_KEY=
STEAM_MONITOR_STEAM_ID=
STEAM_MONITOR_NOTIFY_USER_ID=
STEAM_MONITOR_PROXY_URL=http://127.0.0.1:10808
STEAM_MONITOR_INTERVAL_MS=120000
# STEAM_MONITOR_NO_PROXY=1
# STEAM_MONITOR_STATE_PATH=./data/steam-friends-state.json
# 同一轮里多条变更时分条发送的间隔（毫秒；兼容旧名 STEAM_MONITOR_NOTIFY_GAP_MS）
STEAM_MONITOR_MESSAGE_GAP_MS=450

# 子实例冷启动恢复：login 若长时间不返回则超时失败
# BOT_RESTORE_LOGIN_TIMEOUT_MS=15000
# 后台启动长轮询后，等待 bot.isRunning 的最长时间（默认 60000；SDK 的 start() 本身会永久 await 轮询）
# BOT_POLL_READY_TIMEOUT_MS=60000

LOG_LEVEL=info
# 噪声日志节流：微信 SDK [poller] Poll error 等断网刷屏，同类只提示一次后按此窗口静默（毫秒，默认 5 分钟；0=不节流）
# WX_NOISE_LOG_THROTTLE_MS=300000

# ── QQ 机器人（官方 Bot API v2 + WebSocket，与会话层并列）────────────────
# QQ_BOT_ENABLED=1
# QQ_BOT_APP_ID=
# QQ_BOT_CLIENT_SECRET=
# 或直接使用平台 BotToken（与 clientSecret 二选一）
# QQ_BOT_TOKEN=
# QQ_BOT_SANDBOX=0
# QQ_BOT_INSTANCE_ID=qq-main
# 逗号分隔 intent 名或位掩码数字
# QQ_BOT_INTENTS=C2C,DIRECT_MESSAGE,PUBLIC_GUILD_MESSAGES
# QQ_SESSION_STORE_PATH=./data/sessions.qq-main.json
# QQ_TRACE_IO=0
# 运行时 /用户 机器人 登录 保存的凭证（启动时自动加载）
# QQ_BOT_CONFIG_PATH=./data/qq-bot-config.json
# 转发层出站网络重试（微信/QQ 共用；仅 fetch failed / 5xx / 429 等）
# OUTBOUND_DELIVER_MAX_RETRIES=3
# OUTBOUND_DELIVER_RETRY_MS=800
# 失败落盘队列（微信 iLink 限制、网络失败等与 QQ 共用）
# OUTBOUND_RETRY_QUEUE_PATH=./data/outbound-retry-queue.json
# OUTBOUND_QUEUE_DRAIN_MAX=20
# 每用户最多保留的待补发条数（循环队列，超出丢最旧；0=不限）
# OUTBOUND_QUEUE_MAX_PER_USER=10
# 单条最大重试次数，达到后静默丢弃（0=不按次数清除）
# OUTBOUND_QUEUE_MAX_ATTEMPTS=5
# 入队存活时长上限（毫秒），超过后静默丢弃（0=不按时长清除；默认 1 天）
# OUTBOUND_QUEUE_TTL_MS=86400000
# 兼容旧名：
# QQ_DELIVER_MAX_RETRIES=3
# QQ_DELIVER_RETRY_MS=800
# WSS 连接失败后后台重连间隔（毫秒）
# QQ_BOT_RETRY_MS=15000
