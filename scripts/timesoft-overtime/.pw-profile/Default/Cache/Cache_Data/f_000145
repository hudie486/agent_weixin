        function getCookie(cname) {
            var name = cname + "=";
            var ca = document.cookie.split(';');
            for (var i = 0; i < ca.length; i++) {
                var c = ca[i].trim();
                if (c.indexOf(name) == 0) return c.substring(name.length, c.length);
            }
            return "";
        }
        function displayAliSlider() {
            ////console.log("displaySlider ...................");
            new initAliyunCaptcha({
                immediate: true,
                SceneId: '1h7ztzfz', // 场景ID。根据步骤二新建验证场景后，您可以在验证码场景列表，获取该场景的场景ID
                prefix: 'rw2v3t', // 身份标。开通阿里云验证码2.0后，您可以在控制台概览页面的实例基本信息卡片区域，获取身份标
                mode: 'embed', // 验证码模式。popup表示要集成的验证码模式为弹出式。无需修改
                element: '#btnSliderDiv', //页面上预留的渲染验证码的元素，与原代码中预留的页面元素保持一致。
                button: '#btnSlider', // 触发验证码弹窗的元素。button表示单击登录按钮后，触发captchaVerifyCallback函数。您可以根据实际使用的元素修改element的值
                captchaVerifyCallback: aliCaptchaVerifyCallback, // 业务请求(带验证码校验)回调函数，无需修改
                onBizResultCallback: aliOnBizResultCallback, // 业务请求结果回调函数，无需修改
                getInstance: getAliSliderInstance, // 绑定验证码实例函数，无需修改
                slideStyle: {
                    width: 249,
                    height: 30,
                }, // 滑块验证码样式，支持自定义宽度和高度，单位为px。其中，width最小值为320 px
                language: defaultLang, // 验证码语言类型，支持简体中文（cn）、繁体中文（tw）、英文（en）
            });
            ////console.log("displaySlider  111 ");
        }
        function getAliSliderInstance(instance) {
            //console.log("getAliSliderInstance ............... ");
            captcha = instance;
            //console.log("getAliSliderInstance errorStr: "+ errorStr);
            //console.log("getAliSliderInstance ERROR_MESSAGE: "+ "");
            //console.log("getAliSliderInstance sliderVerify "+ getCookie("sliderVerify"));
            if (errorStr == "mailuidpwderror" || getCookie("sliderVerify") == 'false') {
                var uidPwdErrorCount = getCookie("uidPwdErrorCount");
                //console.log("uidPwdErrorCount : "+uidPwdErrorCount);
                if (uidPwdErrorCount == "") { uidPwdErrorCount = 0; }
                uidPwdErrorCount = Number(uidPwdErrorCount);
                uidPwdErrorCount = uidPwdErrorCount + 1;
                if (uidPwdErrorCount < uidPwdErrorNumLimit) {
                    //console.log("getAliSliderInstance uidPwdErrorCount: " + uidPwdErrorCount);
                    document.cookie = "uidPwdErrorCount=" + uidPwdErrorCount;
                    $('#accountLoginBtn').css('background-color', 'grey');
                    $("#accountLoginBtn").prop("disabled", true);
                    $("#forgetpwdtips").hide();
                    $("#autologincheckspan").hide();
                    $('#btnSlider').click();
                    document.cookie = "sliderVerify=false";
                }
                else {
                    document.cookie = "uidPwdErrorCount=0";
                    $("#auth").hide();
                    $("#otpDiv").show();
                }
            }
        }

        function aliCaptchaVerifyCallback(captchaVerifyParam) {
            return new Promise(function (resolve, reject) {
                $.ajax({
                    type: "post",
                    url: "/iiam/verifyAliSlider",
                    contentType: "application/json;utf-8",
                    data: JSON.stringify({
                        captchaVerifyParam: captchaVerifyParam
                    }),
                    success: function (res) {
                        const verifyResult = {
                            captchaResult: res.data
                            // 验证码验证是否通过，boolean类型，必选
                        };
                        resolve(verifyResult);
                    },
                    error: function () {
                        reject()
                    }
                });
            });
        }
        function aliOnBizResultCallback(verifyResult) {
            if (verifyResult) {
                // 验证通过，可继续下一步操作。
                //console.log("验证通过，可继续下一步操作。");
                $("#accountLoginBtn").prop("disabled", false);
                $('#accountLoginBtn').css('background-color', '#008bd6');
                $("#btnSliderDiv").hide();
                $("#forgetpwdtips").show();
                if ($("#ticket").val != '') {
                    $("#autologincheckspan").show();
                }
                errorStr = "";
                document.cookie = "sliderVerify=true";
                // window.location.href = '/'
            } else {
                ////console.log("滑块安全验证不通过");
            }
        }
        $(document).keydown(function (event) {
            if (event.keyCode == 13) {
                event.preventDefault();
                if ($("#otpdiv").css("display") === 'block') {
                    document.getElementById("otpLoginBtn").click();
                }
                if ($("#auth").css("display") === 'block') {
