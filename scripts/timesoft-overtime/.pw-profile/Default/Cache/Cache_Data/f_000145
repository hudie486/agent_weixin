        function makeTimer(seconds, CodeBtn, flag) {
            var __codeTimer = window['__codeTimer' + flag]
            __codeTimer && clearInterval(__codeTimer)
            CodeBtn.addClass('disabled').html(seconds);
            var cacheHtml = translateItem(defaultLang, CodeBtn.attr('data-i18n'));
            __codeTimer = setInterval(function () {
                if (seconds > 1) {
                    CodeBtn.html(--seconds)
                } else {
                    CodeBtn.html(cacheHtml).removeClass('disabled')
                    clearInterval(__codeTimer)
                    __codeTimer = null
                }
            }, 1000)
        }

        function fillMobile(dom, btnName) {
            var codeObj = JSON.parse(localStorage.getItem("code" + btnName) || "{}")
            var keys = Object.keys(codeObj)
