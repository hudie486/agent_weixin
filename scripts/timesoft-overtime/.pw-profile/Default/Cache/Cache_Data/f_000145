            }
        }

        function showTimer(key, btnName) {
            var codeObj = JSON.parse(localStorage.getItem("code" + btnName) || "{}")
            var endTime = codeObj[key]
            if (endTime) {
                var currentTime = +new Date()
                if (endTime > currentTime) {
                    var seconds = Math.ceil((endTime - currentTime) / 1000)
                    makeTimer(seconds, $(btnName))
                    return key
                } else {
                    delete codeObj[key]
                    localStorage.setItem('code' + btnName, JSON.stringify(codeObj))
                    return ''
                }
            } else {
                clearInterval(window['__codeTimer' + btnName])
                var cacheHtml = translateItem(defaultLang, $(btnName).attr('data-i18n'));
                $(btnName).html(cacheHtml).removeClass('disabled')
            }
        }

